<?xml version="1.0" encoding="UTF-8"?>
<templates xml:space="preserve">
    <t t-name="kAIcodescan.CameraScanner">
        <div class="o_kai_codescan p-3">
            <h2>kAIcodescan - Camera Scanner</h2>
            <p t-esc="state.message" class="text-muted"/>

            <div class="mb-3">
                <button class="btn btn-primary me-2" t-on-click="startScan" t-att-disabled="!state.supported or state.running">Start</button>
                <button class="btn btn-secondary" t-on-click="stopScan" t-att-disabled="!state.running">Stop</button>
            </div>

            <div class="border rounded p-2" style="max-width: 700px;">
                <video t-ref="video" autoplay="autoplay" playsinline="playsinline" style="width: 100%; border-radius: 6px; background: #000;"/>
            </div>

            <div class="mt-3" t-if="state.lastBarcode">
                <strong>Last barcode:</strong>
                <span t-esc="state.lastBarcode"/>
            </div>
        </div>
    </t>
</templates>
